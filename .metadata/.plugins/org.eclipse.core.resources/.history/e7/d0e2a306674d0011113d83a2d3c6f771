void Systick_init(uint32_t tick_hz)
{
	//first calculate the count value
	uint32_t count_value=(SYSYTICK_TIM_CLOCK/tick_hz)-1;

	// this value has to be configured system timer registers
	uint32_t *pSRVR = (uint32_t *)0xE000E014;
	uint32_t *pSCSR = (uint32_t *)0xE000E010;

	*pSRVR &= ~(0x00FFFFFF);

	*pSRVR |= count_value;

	*pSCSR |=( 1 << 1);
	*pSCSR |=( 1 << 2);

	*pSCSR |=( 1 << 0); //enables the counter



}

