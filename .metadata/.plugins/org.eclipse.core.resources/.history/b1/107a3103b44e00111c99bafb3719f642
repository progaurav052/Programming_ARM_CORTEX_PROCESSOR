void update_next_task(void)
{
	int state = TASK_BLOCKED_STATE;

	for(int i=0;i< MAX_TASKS;i++)
	{
		current_task++;
		current_task %=MAX_TASKS;
		state = user_tasks[current_task].current_state;
		if((state == TASK_RUNNING_STATE) && (current_task !=0))
			break;
	}
	if(state != TASK_RUNNING_STATE){
		current_task=0; // Basically if none of  tasks is ready to run , than choose idle task
	}

}
__attribute__((naked)) void switch_sp_to_psp(void)
{

   //1. initialize the PSP with TASK1 stack start address

	//get the value of psp of current_task
	__asm volatile("PUSH {LR}"); //preserve LR which connects back to main , this line was added later
	__asm volatile("BL get_psp_value");
	//here the value of LR will get corrupted , so we cant go back to main , so first save LR
	__asm volatile("MSR PSP,R0");
	__asm volatile("POP {LR}");


	//2. change SP to PSP using control register
	__asm volatile("MOV R0,#0x02");
	__asm volatile("MSR CONTROL,R0");
	__asm volatile("BX LR"); // go back using LR

}


