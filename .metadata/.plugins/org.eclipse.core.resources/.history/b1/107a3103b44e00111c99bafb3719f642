void unblock_tasks(void)
{
	for(int i=1;i< MAX_TASKS;i++)
	{
		if(user_tasks[i].current_state !=TASK_RUNNING_STATE)
		{
			if(user_tasks[i].block_count == global_tick_count)
			{
				user_tasks[i].current_state = TASK_RUNNING_STATE;
			}

		}
	}
}

